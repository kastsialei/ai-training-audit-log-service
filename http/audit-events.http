### Reject — denied outcome (still a valid request, just different value)
POST {{host}}/audit-events
Content-Type: application/json

{
  "actor": "mallory@example.com",
  "event_type": "policy.access_denied",
  "resource": "policy:secret-room",
  "outcome": "DENIED",
  "context": {"reason": "missing role"}
}

> {%
    client.test("status is 201", () => client.assert(response.status === 201));
    client.test("outcome is DENIED", () => client.assert(response.body.outcome === "DENIED"));
%}
