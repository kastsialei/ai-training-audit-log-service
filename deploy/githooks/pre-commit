#!/bin/bash
# Pre-commit hook: run spotless:apply on staged Java files
# Requires: Maven, Java 21

set -e

STAGED_JAVA_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.java$' | wc -l)

if [ "$STAGED_JAVA_FILES" -eq 0 ]; then
    exit 0
fi

echo "[pre-commit] Spotless: checking formatting..."

mvn spotless:apply -q

if [ $? -ne 0 ]; then
    echo "[pre-commit] Spotless failed. Fix errors and re-stage."
    exit 1
fi

STAGED_CHANGES=$(git diff --name-only --diff-filter=ACM)

if [ -n "$STAGED_CHANGES" ]; then
    echo "[pre-commit] Spotless reformatted files. Re-staging..."
    git add --renormalize .
fi

exit 0